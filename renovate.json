{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "ignoreDeps": [
    "dotnet-sdk"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "Microsoft.Build"
      ],
      "matchCurrentValue": "/^17/",
      "enabled": false
    }
  ],
  "minimumReleaseAge": "48 hours"
}
